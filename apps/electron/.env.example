# Easy Motion — 开发环境变量
# 复制本文件为 .env 后填写（.env 勿提交到 Git）

NODE_ENV=development
ELECTRON_ENABLE_LOGGING=1

# Python 服务（pnpm dev:all）
PYTHON_PORT=8000
PYTHON_DEBUG=1

# LLM — Anthropic 兼容协议（MiniMax / Claude 等）
# 优先使用应用内「AI 助手 → 设置」保存到 ~/.easymotion/secrets.json
# 以下为开发环境后备（未在设置中保存 Key 时生效）
LLM_PROVIDER=anthropic
ANTHROPIC_BASE_URL=https://api.minimaxi.com/anthropic
ANTHROPIC_API_KEY=
LLM_MODEL=MiniMax-M3
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.7
