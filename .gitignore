# EasyMotion - Git Ignore
# Node.js + Electron + TypeScript + Python 项目

# ─────────────────────────────────────────
# 系统文件
# ─────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*.swo
*~
.AppleDouble
.LSOverride
desktop.ini
$RECYCLE.BIN/

# ─────────────────────────────────────────
# 编辑器/IDE
# ─────────────────────────────────────────
.vscode/
.idea/
*.iml
*.sublime-*

# ─────────────────────────────────────────
# OpenCode / AI 工具
# ─────────────────────────────────────────
.opencode/
.omo/

# ─────────────────────────────────────────
# Node.js / pnpm
# ─────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
package-lock.json
yarn.lock

# ─────────────────────────────────────────
# 构建产物 / 输出
# ─────────────────────────────────────────
dist/
build/
out/
*.asar
release/

# ─────────────────────────────────────────
# Python
# ─────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
.Python
env/
venv/
ENV/
.venv
pip-log.txt
pip-delete-this-directory.txt

# ─────────────────────────────────────────
# 日志 / 临时文件
# ─────────────────────────────────────────
logs/
*.log
tmp/
temp/
*.tmp

# ─────────────────────────────────────────
# 测试覆盖报告
# ─────────────────────────────────────────
.coverage
htmlcov/
.nyc_output/
coverage/

# ─────────────────────────────────────────
# 环境变量 / 密钥
# ─────────────────────────────────────────
.env
.env.local
.env.*.local

# ─────────────────────────────────────────
# 本地数据 / 缓存（运行时生成）
# ─────────────────────────────────────────
*.db
*.db.bak
*.db-journal
*.db-wal
.thumbnails/
crashes/
settings.local.json

# ─────────────────────────────────────────
# 项目特定（EasyMotion）
# ─────────────────────────────────────────
# 用户本地项目目录
~/EasyMotion/

# 临时导出文件
*.mp4
*.webm
*.mov
*.gif
*.zip

# Python 数据目录
apps/python/data/
apps/python/__pycache__/

# Remotion 渲染输出
remotion-render/

# 本地模板缓存
resources/templates/*/node_modules/
